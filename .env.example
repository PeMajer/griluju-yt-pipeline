# Databáze a Redis — odpovídají docker-compose.yml službám
DATABASE_URL=postgresql://postgres:password@db:5432/griluju_yt_pipeline_development
REDIS_URL=redis://redis:6379/0

# API klíč pro blog agenta — sdílená hodnota s blogovým projektem (PIPELINE_API_KEY)
# Generuj: openssl rand -hex 32
BLOG_API_KEY=changeme-generate-with-openssl-rand-hex-32

# Sidekiq Web UI — http://localhost:3000/sidekiq
SIDEKIQ_WEB_USERNAME=admin
SIDEKIQ_WEB_PASSWORD=changeme

RAILS_ENV=development
